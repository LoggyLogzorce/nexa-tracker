# Environment (development / production)
ENV=development

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=nexa_tracker
DB_SSLMODE=disable

# JWT
JWT_SECRET=your-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Upload
UPLOAD_PATH=./uploads

#Cookie Settings
COOKIE_DOMAIN=.example.com

# HTTP/HTTPS
# (false в development)
COOKIE_SECURE=false

# SameSite
# default = 1 | Lax = 2 | Strict = 3 | None = 4
COOKIE_SAMESITE=3

# Custom Modules
# true | false
NOTIFY_MODULE=false